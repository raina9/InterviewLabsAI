              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"sessionId\": \"7c9e6679-7425-40de-944b-e07fc1f90ae7\",\n  \"firstQuestion\": \"Tell me about a time you had to debug a production incident under pressure. What was your approach?\",\n  \"totalQuestions\": 8\n}"
            }
          ]
        },
        {
          "name": "Submit answer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Dev-Token", "value": "{{devToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answer\": \"I had a Kafka consumer group falling behind during a traffic spike. I checked consumer lag in Grafana first, found we were CPU-bound on deserialization, and scaled partitions plus consumer instances to restore throughput within 20 minutes.\",\n  \"voiceUsed\": false\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/interview/{{sessionId}}/respond", "host": ["{{baseUrl}}"], "path": ["api", "v1", "interview", "{{sessionId}}", "respond"] }
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "POST", "url": { "raw": "{{baseUrl}}/api/v1/interview/{{sessionId}}/respond", "host": ["{{baseUrl}}"], "path": ["api", "v1", "interview", "{{sessionId}}", "respond"] } },
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"agentResponse\": \"Good instinct checking lag first. Let's go deeper — how did you decide partition count vs consumer count to scale?\",\n  \"sessionComplete\": false,\n  \"mentorFeedback\": {\n    \"feedbackGood\": \"Clear diagnostic sequence — metrics before action.\",\n    \"feedbackImprove\": \"Didn't mention how you validated the fix held after scaling.\",\n    \"refinedAnswer\": \"...after scaling, I confirmed consumer lag returned to near-zero over the next two polling intervals before closing the incident.\",\n    \"modelAnswer\": \"A strong answer names the specific metric, the root cause hypothesis, the remediation, and a follow-up verification step.\",\n    \"psychologyNote\": \"Interviewers weight verification steps heavily — it signals you don't consider an incident closed until you've confirmed it.\",\n    \"score\": 7\n  },\n  \"psychologyNudge\": null\n}"
            }
          ]
        },
