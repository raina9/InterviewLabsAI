# =============================================================================
# Interview Lab — Environment Variables Reference
# =============================================================================
# Copy this file: cp .env.example .env
# Edit .env with your real credentials.
# NEVER commit .env to version control — it is in .gitignore.
#
# Variables without defaults are REQUIRED in production.
# Variables with defaults are optional (default shown is for local dev).
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================

# Service name — used in logs, distributed tracing, service discovery
APP_NAME=interview-lab

# Deployment mode — read by two independent config beans:
#   app.rate-limit.mode:   personal (relaxed) | public (strict) | embedded (per-tenant)
#   app.deployment.mode:   personal | production — DeploymentModeValidator only enforces
#                          hard prerequisites (AUTH_MODE=oauth, REDIS_URL set) when this is "production"
DEPLOYMENT_MODE=personal

# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================

# PROD: Supabase connection string (use Transaction pooler URL for Railway compatibility)
# LOCAL: matches docker-compose.yml postgres service defaults
DB_URL=jdbc:postgresql://localhost:5432/interviewlab
DB_USERNAME=interviewlab
DB_PASSWORD=interviewlab

# HikariCP connection pool — tune per Supabase tier (free tier max: 15 connections)
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=2
# Max time a request waits for a pooled connection before HikariCP gives up
DB_POOL_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000
DB_MAX_LIFETIME_MS=1800000

# Docker Compose postgres service credentials (used by docker-compose.yml)
POSTGRES_DB=interviewlab
POSTGRES_USER=interviewlab
POSTGRES_PASSWORD=interviewlab
POSTGRES_PORT=5432

# JPA batch sizes — reduce round trips for bulk operations
JPA_BATCH_FETCH_SIZE=50
JPA_BATCH_SIZE=25

# =============================================================================
# SECURITY — JWT
# =============================================================================

# REQUIRED — no default. Application will refuse to start if missing.
# Generate: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_BASE64_64_BYTE_SECRET

# Access token validity (milliseconds): 86400000 = 24 hours
JWT_ACCESS_EXPIRY_MS=86400000

# Refresh token validity (milliseconds): 2592000000 = 30 days
JWT_REFRESH_EXPIRY_MS=2592000000

# Issuer claim in JWT — used for validation
JWT_ISSUER=interview-lab

# =============================================================================
# AUTH — Google OAuth2
# =============================================================================

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorised redirect URI must match GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET

# LOCAL: localhost | PROD: https://your-railway-domain.railway.app/api/v1/auth/oauth2/callback
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth2/callback

# URL backend redirects to after successful OAuth2 login (frontend receives the JWT cookie)
# LOCAL: React dev server | PROD: Vercel URL
FRONTEND_REDIRECT_URL=http://localhost:3000

# =============================================================================
# AI — Gemini (V1 active provider)
# =============================================================================

# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-pro

# Token budgets per agent — override to manage quota usage
# InterviewAgent: higher temperature for varied questions
GEMINI_INTERVIEW_MAX_INPUT=8192
GEMINI_INTERVIEW_MAX_OUTPUT=2048
GEMINI_INTERVIEW_TEMP=0.7

# MentorAgent: lower temperature for consistent, precise feedback
GEMINI_MENTOR_MAX_INPUT=12288
GEMINI_MENTOR_MAX_OUTPUT=4096
GEMINI_MENTOR_TEMP=0.3

# Sliding window context: number of past messages sent to agent per turn
AI_CONTEXT_WINDOW=10

# LLM call timeout (milliseconds)
AI_TIMEOUT_MS=30000

# Active AI provider — Strategy pattern: change to swap without code changes
# Values: gemini | claude (parked) | openai (parked)
AI_PROVIDER=gemini

# =============================================================================
# AI REQUEST QUEUE + DAILY BUDGET KILL SWITCH (see AIRequestQueue, AiBudgetGuard, ADR-011)
# Every AI provider call passes through both, regardless of which provider is active.
# =============================================================================

# Max concurrent in-flight AI calls — bounds load against a slow/local LLM
AI_MAX_CONCURRENT=5

# Seconds a request waits for a free queue slot before failing with AI_BUSY (429 + Retry-After)
AI_QUEUE_TIMEOUT_SECONDS=30

# Hard daily cap on AI calls across ALL users, ALL providers — runaway-bill protection.
# Breach logs "[AI_BUDGET_ALERT]" (alert-friendly marker) and returns 503 AI_BUDGET_EXHAUSTED.
AI_DAILY_GLOBAL_LIMIT=1000

# =============================================================================
# SESSION STORE — ephemeral quiz/drill/code challenge state + rate limit counters
# =============================================================================

# memory (default): InMemorySessionStore, zero infra, single-instance only
# redis: RedisSessionStore, multi-instance safe — required when DEPLOYMENT_MODE=production
SESSION_STORE=memory

# Leave blank for memory mode. Required when SESSION_STORE=redis or DEPLOYMENT_MODE=production.
# Format: redis://[:password@]host:port  (Upstash/ElastiCache: use rediss:// for TLS)
# Active OSS: self-hosted Redis / Upstash Redis. AWS equivalent: ElastiCache for Redis.
REDIS_URL=

# TTL (hours) before quiz/drill/code challenge state expires in the session store
QUIZ_TTL_HOURS=2
DRILL_TTL_HOURS=2
CODE_TTL_HOURS=4

# =============================================================================
# RATE LIMITING
# =============================================================================

# Max interview interactions per user per day (fixed window, resets at local midnight)
DAILY_LIMIT=60

# =============================================================================
# KAFKA — Messaging
# =============================================================================

# LOCAL: Docker Compose kafka service
# PROD (Upstash): copy the bootstrap URL from Upstash console (format: host:port)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Consumer group — all instances share this group for load balancing
KAFKA_CONSUMER_GROUP=interview-lab-group

# earliest: read from beginning on first consumer start (no event loss on deploy)
KAFKA_OFFSET_RESET=earliest

# Producer reliability: all = leader + all ISR replicas must acknowledge
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3

# Docker Compose kafka service port
KAFKA_PORT=9092

# Log retention: 168h = 7 days (local dev)
KAFKA_LOG_RETENTION_HOURS=168

# Upstash prod SASL/TLS settings (uncomment and set when using Upstash)
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
# For Upstash: org.apache.kafka.common.security.plain.PlainLoginModule required username="..." password="...";
KAFKA_SASL_JAAS_CONFIG=

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_SQL=WARN
LOG_LEVEL_KAFKA=WARN

# Set to true to print SQL queries to console (dev only)
LOG_SQL=false

# =============================================================================
# OBSERVABILITY — Actuator
# =============================================================================

# Comma-separated list of actuator endpoints to expose
ACTUATOR_ENDPOINTS=health,info,metrics

# never | when-authorized | always
HEALTH_SHOW_DETAILS=when-authorized
HEALTH_SHOW_COMPONENTS=when-authorized

# =============================================================================
# API / SWAGGER
# =============================================================================

# Master switch — false takes swagger-ui AND api-docs fully offline (both 404).
# Default true is fine for personal mode; production SHOULD set this to false.
SWAGGER_ENABLED=true

# Enable Swagger Try-it-out (disable in prod to prevent live API calls via Swagger).
# DEPLOYMENT_MODE=production forces this off regardless of this value — see
# SwaggerProductionHardener. Still worth setting false explicitly in prod .env files.
SWAGGER_TRY_IT=true
SWAGGER_SHOW_ACTUATOR=false

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_MAX_AGE=3600

# =============================================================================
# JUDGE0 — Code execution sandbox (open source, self-hostable)
# Leave blank to disable code execution — AI code review is used as fallback.
# Self-host: https://github.com/judge0/judge0
# Managed: https://rapidapi.com/judge0-official/api/judge0-ce (free tier limited)
# =============================================================================

JUDGE0_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_judge0_api_key

# =============================================================================
# AWS — Plug-in ready (all commented — activate when cost rule triggers migration)
# Unpark trigger: traffic demand exceeds zero-cost tier → cost rule → migrate OSS → AWS
# =============================================================================

# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=interview-lab-assets        # Active OSS: MinIO (S3StorageService interface)
# AWS_S3_ENDPOINT=https://s3.amazonaws.com
# AWS_SQS_QUEUE_URL=https://sqs...          # Active OSS: Kafka (SQSMessagePublisher interface)
# AWS_SQS_DLQ_URL=https://sqs...
# AWS_LOG_GROUP=/interview-lab/app           # Active OSS: Loki (CloudWatchLogger interface)
# AWS_RDS_ENDPOINT=...                       # Active OSS: Supabase / local PostgreSQL

# =============================================================================
# DATADOG APM — Plug-in ready (Java agent, not a Spring dependency)
# Activation: set JAVA_OPTS=-javaagent:/path/to/dd-java-agent.jar in Railway env
# Download: https://github.com/DataDog/dd-trace-java/releases
# =============================================================================

# DD_AGENT_HOST=localhost
# DD_AGENT_PORT=8126
# DD_SERVICE=interview-lab
# DD_ENV=production
# DD_VERSION=1.0.0
